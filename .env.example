# Telegram Bot — get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Sanad's personal Telegram chat ID (default: 422035227)
TELEGRAM_CHAT_ID=422035227

# WhatsApp business number — format: country code + number, no spaces or dashes
NEXT_PUBLIC_WHATSAPP_NUMBER=972501234567

# Phone number shown in nav strip and footer
NEXT_PUBLIC_PHONE_NUMBER=050-1234567

# Warehouse address shown in footer
NEXT_PUBLIC_BUSINESS_ADDRESS=עוספיא / דלית אל כרמל, הכרמל

# Business registration number (ח"פ) — shown in footer
NEXT_PUBLIC_VAT_ID=XXXXXXXX

# Admin API key for /api/order auth (defaults to hardcoded if not set)
ADMIN_API_KEY=admin-abu-amin-2026
