# Telegram Bot — get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Sanad's personal Telegram chat ID (default: 422035227)
TELEGRAM_CHAT_ID=422035227

# WhatsApp business number — format: country code + number, no spaces or dashes
# Real number: 052-3158796 → 972523158796
NEXT_PUBLIC_WHATSAPP_NUMBER=972523158796

# Phone numbers shown in nav strip, footer, about, contact pages
# Landline: 04-8599333
NEXT_PUBLIC_PHONE_NUMBER=04-8599333

# Mobile / WhatsApp
NEXT_PUBLIC_PHONE_MOBILE=052-3158796

# Warehouse address shown in footer and contact page
NEXT_PUBLIC_BUSINESS_ADDRESS=כביש ראשי דלית עוספיא, מול אמל חשמל, עוספיה

# Business registration number (ח"פ) — shown in footer when set
# Owner needs to provide this value
NEXT_PUBLIC_VAT_ID=

# Admin API key for /api/order auth (REQUIRED — no default)
ADMIN_API_KEY=

# HMAC secret for admin session cookies (REQUIRED — generate with: openssl rand -hex 32)
ADMIN_SESSION_SECRET=
