{
  "$schema": "https://design-tokens.org/format/1.0",
  "brand": {
    "name": "אבו אמין חלפים",
    "tagline": "מס׳ 1 בכרמל",
    "version": "1.0.0"
  },
  "color": {
    "yellow": {
      "50":  { "$value": "#FEFAE8", "$type": "color", "$description": "Lightest yellow — backgrounds" },
      "100": { "$value": "#FCF4C3", "$type": "color", "$description": "Light yellow — badges, tints" },
      "200": { "$value": "#F9E97F", "$type": "color", "$description": "Yellow 200" },
      "300": { "$value": "#F7DC4A", "$type": "color", "$description": "Yellow 300" },
      "400": { "$value": "#F6D21E", "$type": "color", "$description": "Hover yellow" },
      "500": { "$value": "#F5C300", "$type": "color", "$description": "PRIMARY — Torque Yellow — logo, CTAs" },
      "600": { "$value": "#D4A800", "$type": "color", "$description": "Hover state on yellow" },
      "700": { "$value": "#A88500", "$type": "color", "$description": "Active/pressed yellow" },
      "800": { "$value": "#7C6200", "$type": "color", "$description": "Dark yellow" },
      "900": { "$value": "#524100", "$type": "color", "$description": "Near-black yellow" }
    },
    "black": {
      "50":  { "$value": "#FAFAF8", "$type": "color", "$description": "Near-white with warm cast" },
      "100": { "$value": "#F5F4F0", "$type": "color", "$description": "Light warm surface" },
      "200": { "$value": "#E8E7E2", "$type": "color", "$description": "Light border" },
      "300": { "$value": "#D0CFC8", "$type": "color", "$description": "Divider" },
      "400": { "$value": "#9E9D95", "$type": "color", "$description": "Placeholder" },
      "500": { "$value": "#6B6A62", "$type": "color", "$description": "Secondary text" },
      "600": { "$value": "#47463F", "$type": "color", "$description": "Body text (light mode)" },
      "700": { "$value": "#2C2B25", "$type": "color", "$description": "Subheadings (light mode)" },
      "800": { "$value": "#1A1915", "$type": "color", "$description": "Headings (light mode)" },
      "900": { "$value": "#0A0A08", "$type": "color", "$description": "Industrial Black — primary dark" }
    },
    "surface": {
      "bg":          { "$value": "#0A0A0A", "$type": "color", "$description": "Page background" },
      "card":        { "$value": "#141414", "$type": "color", "$description": "Card background" },
      "raised":      { "$value": "#1F1F1F", "$type": "color", "$description": "Elevated surface" },
      "high":        { "$value": "#272727", "$type": "color", "$description": "Tooltip, dropdown" },
      "borderSubtle":{ "$value": "#2A2A2A", "$type": "color", "$description": "Subtle dividers" },
      "borderStrong":{ "$value": "#3A3A3A", "$type": "color", "$description": "Visible borders" }
    },
    "text": {
      "primary":  { "$value": "#F5F5F5", "$type": "color", "$description": "Primary text (dark bg)" },
      "muted":    { "$value": "#A0A0A0", "$type": "color", "$description": "Secondary text" },
      "dim":      { "$value": "#666666", "$type": "color", "$description": "Metadata, timestamps" },
      "disabled": { "$value": "#444444", "$type": "color", "$description": "Disabled state text" }
    },
    "semantic": {
      "success": { "$value": "#22C55E", "$type": "color" },
      "warning": { "$value": "#F59E0B", "$type": "color" },
      "error":   { "$value": "#EF4444", "$type": "color" },
      "info":    { "$value": "#3B82F6", "$type": "color" }
    }
  },
  "typography": {
    "fontFamily": {
      "heading": { "$value": "Heebo, 'Arial Hebrew', David, system-ui, sans-serif", "$type": "fontFamily" },
      "body":    { "$value": "Heebo, 'Arial Hebrew', David, system-ui, sans-serif", "$type": "fontFamily" }
    },
    "fontWeight": {
      "regular": { "$value": 400, "$type": "fontWeight" },
      "bold":    { "$value": 700, "$type": "fontWeight" },
      "black":   { "$value": 900, "$type": "fontWeight" }
    },
    "fontSize": {
      "xs":   { "$value": "0.75rem",  "$type": "dimension" },
      "sm":   { "$value": "0.875rem", "$type": "dimension" },
      "base": { "$value": "1rem",     "$type": "dimension" },
      "lg":   { "$value": "1.125rem", "$type": "dimension" },
      "xl":   { "$value": "1.333rem", "$type": "dimension" },
      "2xl":  { "$value": "1.777rem", "$type": "dimension" },
      "3xl":  { "$value": "2.369rem", "$type": "dimension" },
      "4xl":  { "$value": "3.157rem", "$type": "dimension" }
    }
  },
  "tailwindExtend": {
    "colors": {
      "brand": {
        "50":  "#FEFAE8",
        "100": "#FCF4C3",
        "200": "#F9E97F",
        "300": "#F7DC4A",
        "400": "#F6D21E",
        "500": "#F5C300",
        "600": "#D4A800",
        "700": "#A88500",
        "800": "#7C6200",
        "900": "#524100"
      }
    },
    "fontFamily": {
      "heading": ["Heebo", "Arial Hebrew", "David", "system-ui", "sans-serif"],
      "body":    ["Heebo", "Arial Hebrew", "David", "system-ui", "sans-serif"]
    }
  }
}
